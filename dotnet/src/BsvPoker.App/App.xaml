<Application x:Class="BsvPoker.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- NO StartupUri: the main window is NOT auto-shown. App.OnStartup runs the wallet selector → password
         FIRST (sequential, with NOTHING behind them) and only THEN shows the main window. -->
    <Application.Resources>
        <SolidColorBrush x:Key="Bg" Color="#0D0D0D" />
        <SolidColorBrush x:Key="Fg" Color="#EEEEEE" />
        <SolidColorBrush x:Key="Accent" Color="#2E7D32" />
        <SolidColorBrush x:Key="Warn" Color="#C77800" />

        <!-- CONTRAST GUARANTEE (the principal's absolute rule: NEVER same-colour text on same-colour background).
             The dark theme sets a light Foreground on the whole window, so ANY input left with its default WHITE
             background would render light-text-on-white = invisible. These implicit styles give EVERY text input
             across the ENTIRE app (main window AND every dialog) an explicit dark background with light text, so
             there is never a white-on-white (or any same-colour) field anywhere. -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="CaretBrush" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding" Value="4,3,4,3" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="CaretBrush" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
            <Setter Property="Padding" Value="4,3,4,3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E1E1E" />
            <Setter Property="Foreground" Value="#ECECEC" />
            <Setter Property="BorderBrush" Value="#3A3A3A" />
        </Style>
    </Application.Resources>
</Application>
