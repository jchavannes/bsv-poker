<Window x:Class="BsvPoker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BSV Poker" Width="1100" Height="820"
        WindowStartupLocation="CenterScreen" WindowState="Normal" ShowActivated="False"
        Icon="poker.ico"
        Background="{StaticResource Bg}" Foreground="{StaticResource Fg}"
        FontFamily="Segoe UI" FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource Warn}" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Foreground="Black" FontWeight="Bold" Text="BSV POKER" VerticalAlignment="Center" Margin="0,0,16,0" />
                <TextBlock Foreground="Black" Text="Network:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox x:Name="NetworkBox" Width="140" VerticalAlignment="Center">
                    <ComboBoxItem Content="Mainnet" />
                    <ComboBoxItem Content="Testnet" />
                    <ComboBoxItem Content="Regtest" />
                </ComboBox>
                <TextBlock x:Name="NetInfo" Foreground="Black" Text="   peer-to-peer · no server" VerticalAlignment="Center" Margin="8,0,0,0" />
            </StackPanel>
        </Border>
        <TabControl x:Name="Tabs" Grid.Row="1" Background="{StaticResource Bg}" Foreground="Black" BorderThickness="0">
            <TabItem Header="Wallet"><ContentControl x:Name="WalletHost" /></TabItem>
            <TabItem Header="Lobby"><ContentControl x:Name="LobbyHost" /></TabItem>
            <TabItem Header="Game"><ContentControl x:Name="GameHost" /></TabItem>
            <TabItem Header="Replay"><ContentControl x:Name="ReplayHost" /></TabItem>
            <TabItem Header="Chat"><ContentControl x:Name="ChatHost" /></TabItem>
            <TabItem Header="Help"><ContentControl x:Name="HelpHost" /></TabItem>
        </TabControl>
    </Grid>
</Window>
