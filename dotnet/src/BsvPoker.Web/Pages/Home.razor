@page "/"
@implements IAsyncDisposable
@using BsvPoker.Crypto
@using BsvPoker.Core
@using BsvPoker.Core.Games
@using BsvPoker.Net
@using BsvPoker.Web.Transport
@inject IJSRuntime JS

<PageTitle>BSV Poker — Group Blackjack (web)</PageTitle>

<div class="felt">
  <h1>BSV Poker — Group Blackjack <span class="tag">web · local P2P</span></h1>

  @if (_bj is null)
  {
    <div class="panel">
      <p>The same on-chain group-blackjack protocol as the desktop app, running <b>directly in your browser</b>.
         It's server-less: every open tab on this site is a peer (via BroadcastChannel). <b>Open this page in a
         second tab</b> and click <i>Join the table</i> in both — the deal starts the instant two seats are filled.</p>
      <label>Table&nbsp;<input @bind="_table" size="22" /></label>
      <label>Seats&nbsp;
        <select @bind="_seats">
          <option>2</option><option>3</option><option>4</option><option>5</option><option>6</option>
        </select>
      </label>
      <button class="go" @onclick="Join">Join the table</button>
      <p class="muted">You are player <code>@Me()</code></p>
    </div>
  }
  else
  {
    <div class="status">@_bj.Status</div>
    <div class="bank">Hand #@_bj.HandNumber &nbsp;·&nbsp; You: <b>@_bj.MyBankroll</b> &nbsp;·&nbsp; House: <b>@_bj.DealerBankroll</b></div>

    <div class="players">@Players()</div>

    <div class="lane">
      <div class="label">Dealer (shared)</div>
      <div class="cards">
        @foreach (var c in _bj.DealerCards) { <span class="card @(c.IsRed?"red":"")">@c.RankLabel@c.Glyph</span> }
        @if (_bj.State == NetBlackjack.Phase.Playing && _bj.DealerCards.Count == 1) { <span class="card back">🂠</span> }
      </div>
      @if (DealerOpen()) { <div class="total">Dealer: @BjVal(_bj.DealerCards)</div> }
    </div>

    <div class="lane">
      <div class="label">Your hand@(_bj.MySeat >= 0 ? $" (seat {_bj.MySeat})" : "")</div>
      <div class="cards">
        @foreach (var c in _bj.MyHand) { <span class="card @(c.IsRed?"red":"")">@c.RankLabel@c.Glyph</span> }
      </div>
      @if (_bj.MyHand.Count > 0) { <div class="total">Your total: @BjVal(_bj.MyHand)</div> }
    </div>

    <div class="actions">
      <button @onclick="() => Act(BjAction.Hit)"    disabled="@(!_bj.MyTurn)">Hit</button>
      <button @onclick="() => Act(BjAction.Stand)"  disabled="@(!_bj.MyTurn)">Stand</button>
      <button @onclick="() => Act(BjAction.Double)" disabled="@(!_bj.MyTurn || _bj.MyHand.Count != 2)">Double</button>
      <button class="leave" @onclick="Leave">@(_bj.SessionOver ? "Closed" : "Leave table")</button>
    </div>
  }
</div>

@code {
    private BroadcastChannelTransport? _mesh;
    private NetBlackjack? _bj;
    private byte[] _priv = Array.Empty<byte>(), _pub = Array.Empty<byte>();
    private string _table = "web-table";
    private string _seats = "2";

    protected override void OnInitialized()
    {
        var kp = Secp256k1.GenerateKeyPair();   // a fresh identity for this tab (a 2nd tab = a 2nd player)
        _priv = kp.Priv; _pub = kp.Pub;
    }

    private string Me() => _pub.Length == 33 ? Convert.ToHexString(_pub)[..8].ToLowerInvariant() : "—";

    private async Task Join()
    {
        _mesh = await BroadcastChannelTransport.CreateAsync(JS);
        var tableId = $"{_table}~p{_seats}~b10";
        _bj = new NetBlackjack(_mesh, tableId, _priv, _pub);
        _bj.OnUpdate += OnUpdate;
        _bj.Start();
        StateHasChanged();
    }

    private void OnUpdate() => _ = InvokeAsync(StateHasChanged);

    private void Act(BjAction a) { _bj?.Act(a); StateHasChanged(); }

    private void Leave()
    {
        if (_bj is null) return;
        if (_bj.SessionOver) { _ = Reset(); return; }
        _bj.Leave(); StateHasChanged();
    }

    private async Task Reset()
    {
        if (_bj is not null) { try { _bj.OnUpdate -= OnUpdate; _bj.Stop(); } catch { } _bj = null; }
        if (_mesh is not null) { try { await _mesh.DisposeAsync(); } catch { } _mesh = null; }
        StateHasChanged();
    }

    private bool DealerOpen() => _bj is not null && _bj.State is NetBlackjack.Phase.DealerPlay or NetBlackjack.Phase.HandOver or NetBlackjack.Phase.Done;
    private static int BjVal(IReadOnlyList<Card> h) => Blackjack.Value(h).Total;

    private string Players()
    {
        if (_bj is null) return "";
        var seats = _bj.SeatPubs;
        if (seats.Length == 0) return "";
        return "At the table: " + string.Join(",  ", seats.Select((p, i) => p[..6] + (i == _bj.MySeat ? " (you)" : "")));
    }

    public async ValueTask DisposeAsync() => await Reset();
}
